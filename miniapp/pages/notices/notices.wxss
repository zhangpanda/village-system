.search-bar { display: flex; padding: 16rpx 24rpx; background: #fff; gap: 12rpx; }
.search-bar input { flex: 1; background: #f5f5f5; border-radius: 12rpx; padding: 12rpx 20rpx; font-size: 28rpx; }
.search-btn { background: #07c160; color: #fff; border-radius: 12rpx; padding: 12rpx 24rpx; font-size: 28rpx; }
.tabs { display: flex; background: #fff; padding: 8rpx 24rpx 16rpx; }
.tab { flex: 1; text-align: center; padding: 12rpx 0; font-size: 28rpx; color: #666; border-radius: 8rpx; }
.tab.active { color: #07c160; font-weight: bold; background: #e6f7ee; }
.notice-row { display: flex; align-items: center; }
.notice-title { font-size: 28rpx; flex: 1; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
