<view class="page" wx:if="{{stats}}">
  <view class="title">管理看板</view>
  <view class="cards">
    <view class="card" bindtap="goTo" data-url="/pages/admin-review/admin-review?type=notice">
      <text class="num">{{stats.notice_pending || 0}}</text>
      <text class="label">待审公告</text>
    </view>
    <view class="card" bindtap="goTo" data-url="/pages/admin-review/admin-review?type=subsidy">
      <text class="num orange">{{stats.subsidy_pending || 0}}</text>
      <text class="label">待审补贴</text>
    </view>
    <view class="card" bindtap="goTo" data-url="/pages/admin-review/admin-review?type=ticket">
      <text class="num red">{{stats.ticket_open || 0}}</text>
      <text class="label">待处理工单</text>
    </view>
    <view class="card" bindtap="goTo" data-url="/pages/admin-review/admin-review?type=finance">
      <text class="num">{{stats.finance_pending || 0}}</text>
      <text class="label">待审财务</text>
    </view>
  </view>
  <view class="menu">
    <view class="menu-item" bindtap="goTo" data-url="/pages/admin-users/admin-users">
      <text>👥 用户管理</text><text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goTo" data-url="/pages/admin-households/admin-households">
      <text>🏠 户籍管理</text><text class="arrow">›</text>
    </view>
  </view>
</view>
