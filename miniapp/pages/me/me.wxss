.login-box { text-align: center; padding: 120rpx 48rpx; }
.profile { display: flex; align-items: center; }
.avatar {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: #07c160; color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; font-weight: bold; margin-right: 24rpx; flex-shrink: 0;
}
.info { flex: 1; }
.name { font-size: 34rpx; font-weight: bold; display: block; }
.phone { font-size: 26rpx; color: #666; margin-top: 6rpx; display: block; }
.detail { font-size: 26rpx; color: #666; margin-top: 4rpx; display: block; }
.role { font-size: 24rpx; color: #999; margin-top: 4rpx; display: block; }
.edit-link { font-size: 26rpx; color: #07c160; flex-shrink: 0; }
.form-item { padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.form-item:last-of-type { border-bottom: none; }
.label { font-size: 26rpx; color: #999; display: block; margin-bottom: 8rpx; }
.form-item input { font-size: 30rpx; }
.btn-cancel {
  margin-left: 16rpx; padding: 20rpx 32rpx; font-size: 30rpx;
  color: #666; background: #f5f5f5; border-radius: 12rpx; text-align: center;
}
.menu { margin: 24rpx; background: #fff; border-radius: 16rpx; overflow: hidden; }
.menu-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28rpx 24rpx; border-bottom: 1rpx solid #f5f5f5; font-size: 30rpx;
}
.menu-item:last-child { border-bottom: none; }
.arrow { color: #ccc; }
.btn-logout {
  margin: 48rpx 24rpx; text-align: center; padding: 20rpx;
  color: #e33; font-size: 30rpx; background: #fff; border-radius: 12rpx;
}

.nickname-mask { position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,.5); display:flex; align-items:center; justify-content:center; z-index:100; }
.nickname-box { background:#fff; border-radius:16rpx; padding:40rpx; width:80%; }
.nickname-input { border:1rpx solid #ddd; border-radius:12rpx; padding:16rpx 20rpx; font-size:30rpx; }

.detail-row { display:flex; justify-content:space-between; padding:12rpx 0; font-size:26rpx; color:#666; border-bottom:1rpx solid #f8f8f8; }
.detail-row:last-of-type { border-bottom:none; }
.detail-label { color:#999; }
.info-tag { font-size:22rpx; background:#f5f5f5; padding:4rpx 12rpx; border-radius:8rpx; color:#666; }
.wx-phone-btn { display: inline-block; font-size: 24rpx; color: #07c160; background: #e8f8ee; border: 1rpx solid #07c160; border-radius: 8rpx; padding: 6rpx 16rpx; margin-top: 8rpx; line-height: 1.5; }