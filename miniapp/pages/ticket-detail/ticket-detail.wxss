.img-list { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 16rpx; }
.img-thumb { width: 160rpx; height: 160rpx; border-radius: 12rpx; }
.comment-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center;
  background: #fff; padding: 16rpx 24rpx;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
.comment-input { flex: 1; background: #f5f5f5; border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 28rpx; }
.comment-send { color: #07c160; font-weight: bold; margin-left: 20rpx; font-size: 28rpx; }
.btn-close { margin-top:20rpx; text-align:center; padding:16rpx 0; color:#e33; font-size:26rpx; border:1rpx solid #e33; border-radius:12rpx; }
