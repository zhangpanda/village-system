.page { padding: 24rpx; }
.card { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 20rpx; }
.title { font-size: 32rpx; font-weight: bold; margin-bottom: 12rpx; }
.info { font-size: 26rpx; color: #666; line-height: 1.8; }
.section { font-size: 28rpx; font-weight: 600; margin: 20rpx 0 12rpx; padding-left: 8rpx; border-left: 6rpx solid #07c160; }
.empty { text-align: center; color: #999; padding: 40rpx; }
.member { background: #fff; border-radius: 12rpx; padding: 20rpx 24rpx; margin-bottom: 12rpx; }
.member-top { display: flex; justify-content: space-between; align-items: center; }
.member-name { font-size: 30rpx; font-weight: 600; color: #07c160; }
.member-rel { font-size: 24rpx; color: #ff9800; background: #fff8e1; padding: 4rpx 12rpx; border-radius: 8rpx; }
.member-actions { margin-top: 12rpx; display: flex; gap: 24rpx; }
.link { font-size: 26rpx; color: #07c160; }
.link.red { color: #e33; }
