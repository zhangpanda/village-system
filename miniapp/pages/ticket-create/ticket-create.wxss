.form-item { padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.form-item:last-child { border-bottom: none; }
.label { font-size: 26rpx; color: #999; display: block; margin-bottom: 8rpx; }
.img-list { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 12rpx; }
.img-thumb { width: 160rpx; height: 160rpx; border-radius: 12rpx; }
.img-add {
  width: 160rpx; height: 160rpx; border-radius: 12rpx;
  background: #f5f5f5; display: flex; align-items: center; justify-content: center;
  font-size: 60rpx; color: #ccc;
}
