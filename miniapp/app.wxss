page {
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  margin: 20rpx 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.btn-primary {
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
}
.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}
.tag-urgent { background: #fee; color: #e33; }
.tag-policy { background: #e6f7ff; color: #1890ff; }
.tag-activity { background: #f6ffed; color: #52c41a; }
.tag-pending { background: #fff7e6; color: #fa8c16; }
.tag-approved { background: #f6ffed; color: #52c41a; }
.tag-rejected { background: #fee; color: #e33; }
.meta { font-size: 24rpx; color: #999; margin-top: 12rpx; }
.empty { text-align: center; padding: 80rpx 0; color: #999; }
